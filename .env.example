# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (Docker Compose): use the values below
# Production: use the real PostgreSQL credentials on the server
DATABASE_URL="postgresql://tms_user:tms_password@localhost:5432/tms_db"

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret (min 32 chars):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-random-string-at-least-32-characters-long"
JWT_EXPIRES_IN="8h"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
# Public base URL of the backend (used in startup log and for self-referencing URLs)
# In production set this to your actual domain, e.g. https://api.yourdomain.com
SERVER_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5173"
# Enables brute-force rate limiting on POST /auth/login (20/15min) and POST /auth/mfa/verify (10/15min).
# Set to 'true' in production. Leave unset in dev, E2E tests, and load/stress tests.
# RATE_LIMIT_ENABLED=true
# Log level: fatal | error | warn | info | debug | trace | silent (default: info)
# LOG_LEVEL="info"
# System admin account — protected from modification/deletion by the app
SEED_USER_EMAIL="admin@tms.ro"
SEED_USER_NAME="Admin TMS"
# System admin password — used by `npx prisma db seed`. Set a strong value in production.
SEED_USER_PASSWORD="change-me-in-production"

# ─── WebAuthn / Passkeys (optional — defaults work for localhost dev) ──────────
# In production: RP_ID = your public domain (no port), ORIGIN = https://yourdomain.com
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=TMS Transport
# WEBAUTHN_ORIGIN=http://localhost:5173

# ─── SmartBill (optional — can also be configured from Settings UI) ──────────
# Set these here only if you want to pre-seed them via environment.
# SMARTBILL_EMAIL=""
# SMARTBILL_API_TOKEN=""
# SMARTBILL_SERIES="BGR"
# SMARTBILL_CIF=""

# ─── AI Features (M26/M27/M28) ───────────────────────────────────────────────
# In Docker Compose stacks, OLLAMA_URL and PYTHON_API_URL default to Docker
# internal hostnames. Override only if running services outside Docker.
# OLLAMA_URL="http://ollama:11434"        # Docker internal default
# Ollama model — 3b is fast but weak; 8b is recommended for better quality
# OLLAMA_MODEL="llama3.1:8b"             # default: llama3.2:3b
# PYTHON_API_URL="http://python-api:8000" # Docker internal default
# Shared secret between Express backend and Python API (min 16 chars)
# PYTHON_API_SECRET="change-me-to-a-random-string"
# Primary AI provider: ollama (local, slow on CPU) | gemini (fast cloud, requires GEMINI_API_KEY)
# Set to 'gemini' for faster responses (1-3s vs 30-60s on CPU-only Ollama)
# AI_PRIMARY_PROVIDER="gemini"
# Cloud LLM fallback when primary is unavailable: gemini | openai | none (default)
# AI_FALLBACK_PROVIDER="gemini"
# GEMINI_API_KEY=""
# OPENAI_API_KEY=""

# ─── PostgreSQL client tool paths ────────────────────────────────────────────
# Override on Windows if pg_dump/psql are not in PATH (e.g. after fresh install).
# On Linux/Docker the defaults ('pg_dump' / 'psql') work as long as postgresql-client is installed.
# PG_DUMP_PATH="C:\Program Files\PostgreSQL\17\bin\pg_dump.exe"
# PSQL_PATH="C:\Program Files\PostgreSQL\17\bin\psql.exe"

# ─── Remote Backup Storage (S3-compatible) ───────────────────────────────────
# All five must be set to enable remote backups. Leave all unset for local-only.
#
# RECOMMENDED FREE OPTION — Cloudflare R2 (10 GB free forever, no egress fees):
#   1. Go to dash.cloudflare.com → R2 → Create bucket (e.g. "tms-backups")
#   2. R2 → Manage R2 API tokens → Create token (Object Read & Write)
#   3. Copy Account ID from the R2 overview page
# BACKUP_S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
# BACKUP_S3_BUCKET="tms-backups"
# BACKUP_S3_REGION="auto"
# BACKUP_S3_ACCESS_KEY="your-r2-access-key-id"
# BACKUP_S3_SECRET_KEY="your-r2-secret-access-key"
#
# Other supported providers (same 5 vars, different endpoint/region):
#   Backblaze B2 : endpoint = https://s3.<region>.backblazeb2.com, region = e.g. us-east-005
#   MinIO (self) : endpoint = http://minio:9000, region = us-east-1
#   AWS S3       : endpoint = https://s3.<region>.amazonaws.com, region = e.g. eu-central-1

# ─── Crypto ───────────────────────────────────────────────────────────────────
# Used for encrypting sensitive fields. Generate: openssl rand -hex 32
# CRYPTO_KEY="change-me-to-a-random-32-byte-hex-string"

# ─── E2E Tests (Playwright) — place in frontend/.env.test or export in shell ──
# Falls back to the dev credentials below if not set.
# E2E_ADMIN_EMAIL="admin@tms.ro"
# E2E_ADMIN_PASSWORD="admin123"

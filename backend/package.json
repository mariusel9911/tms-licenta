{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "reset:orders": "tsx prisma/reset-orders.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage-open": "vitest run --coverage --reporter=html && start coverage/index.html",
    "clean": "rm -rf coverage html dist ./tests/load/reports ./tests/stress/reports ./tests/pdf-stress/reports",
    "test:load": "node --input-type=module -e \"import {mkdirSync} from 'fs'; mkdirSync('tests/load/reports',{recursive:true})\" && k6 run tests/load/scenarios/load-test.js",
    "test:stress": "node --input-type=module -e \"import {mkdirSync} from 'fs'; mkdirSync('tests/load/reports',{recursive:true})\" && k6 run tests/load/scenarios/stress-test.js",
    "test:pdf-stress": "node --input-type=module -e \"import {mkdirSync} from 'fs'; mkdirSync('tests/load/reports',{recursive:true})\" && k6 run tests/load/scenarios/pdf-stress-test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pino-http": "^5.8.4",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.11.14",
    "axios": "^1.13.5",
